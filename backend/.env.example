# Copy to backend/.env and fill in. Never commit the real .env.

# ---- LLM provider (server-side only; never exposed to the client) ----
# Choose one provider: "gemini" or "openai".
LLM_PROVIDER=gemini

# -- Gemini provider --
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# -- OpenAI-compatible provider (OpenAI / xAI Grok / Groq / Ollama / LM Studio) --
# Used when LLM_PROVIDER=openai. Examples:
#   OpenAI:    OPENAI_BASE_URL=                                  OPENAI_MODEL=gpt-4o-mini       OPENAI_JSON_FORMAT=json_object
#   xAI Grok:  OPENAI_BASE_URL=https://api.x.ai/v1               OPENAI_MODEL=grok-2-latest     OPENAI_JSON_FORMAT=json_object
#   Groq:      OPENAI_BASE_URL=https://api.groq.com/openai/v1    OPENAI_MODEL=llama-3.3-70b-versatile
#   LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1          OPENAI_MODEL=<model-id>        OPENAI_JSON_FORMAT=json_schema
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
# How to request JSON: json_object (OpenAI/Grok/Groq) | json_schema (LM Studio) | off
OPENAI_JSON_FORMAT=json_object

# ---- Server ----
PORT=3001
# Comma-separated allowed frontend origins for CORS. Set this to your deployed
# frontend URL in production (keep localhost for dev).
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ---- Persistence (SQLite) ----
DB_PATH=./data/audit.db

# ---- LLM behaviour ----
# Local models can be slow to first-load; raise these when using LM Studio/Ollama.
LLM_TIMEOUT_MS=25000
LLM_MAX_RETRIES=2
RUN_MAX_MS=90000
